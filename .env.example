# Acada Learning - Environment Configuration Example
# 
# INSTRUCTIONS:
# 1. Copy this file to .env: cp .env.example .env
# 2. Update all values with your actual credentials
# 3. DO NOT commit .env to git (it's in .gitignore)
# 4. For EC2 deployment, place .env at /etc/acada/.env or set ENV_FILE_PATH environment variable

# ============================================================
# SMTP Configuration (Email)
# ============================================================
# For Gmail: Use an App Password (not your main password)
# See: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-16-character-app-password
SMTP_FROM_EMAIL=your-email@gmail.com

# ============================================================
# Database Configuration
# ============================================================
# For local Docker development: DB_HOST=acada-postgres
# For AWS RDS: DB_HOST=your-rds-endpoint.rds.amazonaws.com
# For EC2 with separate DB instance: DB_HOST=database-instance-ip-or-hostname
DB_HOST=acada-postgres
DB_PORT=5432
DB_NAME=acada_db
DB_USERNAME=acada_user
DB_PASSWORD=your-strong-database-password-change-this

# ============================================================
# Admin Login Credentials
# ============================================================
# These are used for the admin panel
# Change these from defaults for production!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-strong-admin-password

# ============================================================
# Environment File Location (Optional)
# ============================================================
# Set via environment variable to use a different .env location:
# export ENV_FILE_PATH=/etc/acada/.env
# Then restart Tomcat
